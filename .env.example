# Backend database settings
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bdhatbela_management
DB_USER=root
DB_PASS=

# Optional application settings
APP_TIMEZONE=Asia/Dhaka

# Frontend / Vite settings
VITE_API_BASE_URL=/api/
VITE_API_PROXY_TARGET=http://127.0.0.1:8001

# Optional incident mode / feature flags
VITE_DB_WRITE_FREEZE_TITLE=Read-only incident mode
VITE_DB_WRITE_FREEZE_MESSAGE=Database writes are temporarily disabled for maintenance. You can keep using the app in read-only mode.
VITE_ENABLE_CARRYBEE_SYNC=true
