# Backend database settings
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mamepilot
DB_USER=root
DB_PASS=
# Use your local database credentials for development.

# Application settings
APP_TIMEZONE=Asia/Dhaka
GEMINI_API_KEY=
OPENROUTER_API_KEY=
APP_JWT_SECRET=bdhatbela-change-this-secret
AUDIT_LOG_FILE=/home/your-user/mamepilot_backend/backend/storage/audit/update-log.jsonl
LICENSE_CRON_SECRET=change-this-to-a-long-random-secret
APP_FRONTEND_URL=https://your-domain.example
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v25.0
META_ADS_REDIRECT_URI=https://your-domain.example/api/index.php?action=metaAdsOAuthCallback
META_ADS_OAUTH_SCOPES=email,public_profile,ads_read,business_management
META_LOGIN_CONFIG_ID=
# APP_JWT_SECRET is used for auth token signing.
# AUDIT_LOG_FILE is where update audit logs are written.
# LICENSE_CRON_SECRET is used by deployment update API wrappers.
# META_APP_ID and META_APP_SECRET enable the Meta Ads OAuth connection.
# META_ADS_REDIRECT_URI must match the callback URL configured in Meta.

# Frontend / Vite settings
VITE_API_BASE_URL=/api/
VITE_API_PROXY_TARGET=http://127.0.0.1:8001
# VITE_API_BASE_URL is the browser path to the API.
# VITE_API_PROXY_TARGET is used by Vite in development only.

# Incident mode / feature flags
VITE_DB_WRITE_FREEZE_TITLE=Read-only incident mode
VITE_DB_WRITE_FREEZE_MESSAGE=Database writes are temporarily disabled for maintenance. You can keep using the app in read-only mode.
VITE_ENABLE_CARRYBEE_SYNC=true
# Optional UI text and feature flags for incident mode.

# Automatic update / deployment settings
# For local development, leave UPDATE_ENABLED=0.
UPDATE_ENABLED=0
# Set to 1 in production only when you want automatic update checks enabled.

# Choose how production updates are retrieved:
#   - release package method: UPDATE_USE_GIT=0
#   - git method:             UPDATE_USE_GIT=1
UPDATE_USE_GIT=0

# App and deployment paths
UPDATE_APP_ROOT=/home/your-user/mamepilot_backend
UPDATE_PUBLIC_ROOT=/home/your-user/public_html
UPDATE_DOCUMENT_ROOT_FOLDER=public_html
UPDATE_BACKEND_FOLDER=mamepilot_backend
# UPDATE_APP_ROOT is the backend root for deployed code.
# UPDATE_PUBLIC_ROOT is where frontend files should be published.
# The cPanel package extracts frontend into UPDATE_PUBLIC_ROOT/UPDATE_DOCUMENT_ROOT_FOLDER.
# The backend files are extracted into UPDATE_PUBLIC_ROOT/UPDATE_BACKEND_FOLDER when using release packages.

# Git deployment settings (used only when UPDATE_USE_GIT=1)
UPDATE_GIT_DEPLOY_ROOT=/home/your-user/repositories/Mame Pilot
UPDATE_GIT_URL=https://github.com/SajedurRahmanFiad/MamePilot.git
UPDATE_GIT_BRANCH=main
UPDATE_DOCUMENT_ROOT=/home/your-user/public_html
UPDATE_BACKEND_ROOT=/home/your-user/mamepilot_backend
# UPDATE_GIT_DEPLOY_ROOT is the local git checkout on the server.
# UPDATE_DOCUMENT_ROOT is the final public HTML folder.
# UPDATE_BACKEND_ROOT is where the backend source is deployed.

# Schema and seed settings
UPDATE_SCHEMA_PATH=/home/username/mamepilot_backend/backend/database/schema-only.sql
UPDATE_SEED_PATH=
UPDATE_RUN_SCHEMA=1
UPDATE_RUN_SEED=0
UPDATE_RUN_MIGRATIONS=0
# Leave UPDATE_SCHEMA_PATH/UPDATE_SEED_PATH empty to use the default backend/database files.
# UPDATE_RUN_SEED should remain 0 in production unless you are doing a fresh install.

# Build settings
UPDATE_BUILD_COMMAND=npm run build
UPDATE_SKIP_BUILD=0
# If the server should run frontend build after git pull, leave UPDATE_SKIP_BUILD=0.

# Release package method settings
UPDATE_BASE_URL=https://raw.githubusercontent.com/SajedurRahmanFiad/MamePilot/main/VERSION
UPDATE_VERSION_URL=
UPDATE_VERSION_FILENAME=VERSION
UPDATE_RELEASE_URL=
UPDATE_PACKAGE_NAME=cpanel-mamepilot-package
# With UPDATE_BASE_URL set, the updater downloads:
#   $UPDATE_VERSION_URL
#   $UPDATE_PACKAGE_NAME.zip

# Runtime and backup paths
UPDATE_PROJECT_ROOT=/home/your-user/mamepilot
UPDATE_TEMP_DIR=/tmp
UPDATE_BACKUP_ROOT=/home/your-user/mamepilot_backups
UPDATE_ROLLBACK_ROOT=
UPDATE_CRON_SECRET=use-a-long-random-secret-here
UPDATE_PHP_BINARY=/usr/local/bin/php
# UPDATE_PHP_BINARY can be used when the server's default `php` executable is not available in PATH.
# UPDATE_BACKUP_ROOT stores temporary backups before updates.
# UPDATE_ROLLBACK_ROOT can be used to restore a fallback copy.
# UPDATE_CRON_SECRET protects the update API endpoint.

# Optional maintenance settings
DB_BACKUP_ROOT=/home/your-user/mamepilot_db_backups
DB_DUMP_PATH=mysqldump
DB_MYSQL_PATH=mysql
MIGRATION_PATH=./migrations
# DB_BACKUP_ROOT is used by backup scripts.
# DB_DUMP_PATH and DB_MYSQL_PATH are the mysql client executables.

# cPanel wrapper env vars
# These are read by the cPanel API wrapper scripts if you deploy via the cPanel template.
MAMEPILOT_APP_ROOT=/home/your-user/mamepilot_backend
BDHATBELA_APP_ROOT=/home/your-user/mamepilot_backend
