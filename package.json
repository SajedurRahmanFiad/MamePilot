{
  "name": "mamepilot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend:serve": "php -S 127.0.0.1:8001 -t backend/public",
    "backend:setup": "php backend/bin/setup.php",
    "backend:resync-wallet": "php backend/bin/resync_wallet_credits.php",
    "deploy:cpanel:prepare": "powershell -ExecutionPolicy Bypass -File .\\scripts\\prepare-cpanel-deploy.ps1",
    "deploy:central-license:prepare": "powershell -ExecutionPolicy Bypass -File .\\scripts\\prepare-central-license-api.ps1",
    "deploy:cpanel:prepare:admin": "powershell -ExecutionPolicy Bypass -File .\\scripts\\prepare-cpanel-deploy.ps1 -DocumentRootFolder public_html -BackendFolder mamepilot_backend -PackageName cpanel-mamepilot-package",
    "deploy:cpanel:prepare:admin1": "powershell -ExecutionPolicy Bypass -File .\\scripts\\prepare-cpanel-deploy.ps1 -DocumentRootFolder public_html -BackendFolder mamepilot_backend -PackageName cpanel-mamepilot-package",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.20",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
